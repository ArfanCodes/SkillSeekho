# Supabase — get from https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Razorpay Checkout — public Key ID only (safe to expose client-side).
# The Key Secret must NEVER live here; it belongs in edge-function secrets.
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx

# Map tiles (OpenStreetMap). Optional — defaults to the keyless public OSM
# tile server. For a keyed provider (MapTiler / Stadia / Thunderforest),
# put {key} where the key belongs in the URL template and set the key below.
# VITE_MAP_TILE_URL=https://api.maptiler.com/maps/streets-v2/{z}/{x}/{y}.png?key={key}
# VITE_MAP_TILE_API_KEY=your-map-key
# VITE_MAP_TILE_ATTRIBUTION=© MapTiler © OpenStreetMap contributors

# These go in Supabase Edge Function secrets (NOT in .env — never expose in frontend)
# GROQ_API_KEY=
# SARVAM_API_KEY=
# GEMINI_API_KEY=
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
